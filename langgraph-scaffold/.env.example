# ---- LLM ----
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
# 设为 1 时使用离线 Mock LLM（无需任何 API Key 也能跑通流程）
MOCK_LLM=0

# ---- Checkpointer ----
# memory | sqlite | postgres
CHECKPOINTER=memory
SQLITE_PATH=./.checkpoints.sqlite
POSTGRES_DSN=postgresql://user:pass@localhost:5432/langgraph

# ---- LangSmith 可观测性 ----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_replace_me
LANGCHAIN_PROJECT=langgraph-scaffold
